---

<div class="relative w-full h-32 lg:h-48 overflow-hidden bg-gradient-to-b from-white via-purple-100/60 to-purple-50">
  <svg
    viewBox="0 0 1200 200"
    width="100%"
    height="100%"
    preserveAspectRatio="none"
    class="w-full h-full"
  >
    <defs>
      <linearGradient
        id="transitionWave"
        x1="0%"
        y1="0%"
        x2="0%"
        y2="100%"
      >
        <stop offset="0%" style="stop-color:#ffffff;stop-opacity:0.8" />
        <stop offset="100%" style="stop-color:#f3e8ff;stop-opacity:0.4" />
      </linearGradient>
    </defs>
    <!-- Wave curves -->
    <path
      d="M0,60 Q300,20 600,60 T1200,60 L1200,200 L0,200 Z"
      fill="url(#transitionWave)"
      opacity="0.6"
    />
    <path
      d="M0,80 Q300,40 600,80 T1200,80 L1200,200 L0,200 Z"
      fill="url(#transitionWave)"
      opacity="0.4"
    />
    <path
      d="M0,100 Q300,60 600,100 T1200,100 L1200,200 L0,200 Z"
      fill="url(#transitionWave)"
      opacity="0.2"
    />
  </svg>
</div>
