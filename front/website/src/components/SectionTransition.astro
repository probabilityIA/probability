---
---

<div class="relative w-full h-16 lg:h-24 overflow-hidden bg-gradient-to-b from-[#FBFAFE] via-purple-50/30 to-[#FBFAFE]">
  <svg
    viewBox="0 0 1200 120"
    width="100%"
    height="100%"
    preserveAspectRatio="none"
    class="w-full h-full"
  >
    <defs>
      <linearGradient
        id="waveGradient"
        x1="0%"
        y1="0%"
        x2="0%"
        y2="100%"
      >
        <stop offset="0%" style="stop-color:#8B5CF6;stop-opacity:0.08" />
        <stop offset="100%" style="stop-color:#8B5CF6;stop-opacity:0.02" />
      </linearGradient>
    </defs>
    <!-- Subtle wave line -->
    <path
      d="M0,40 Q300,20 600,40 T1200,40"
      fill="none"
      stroke="url(#waveGradient)"
      stroke-width="1.5"
      opacity="0.4"
    />
    <path
      d="M0,50 Q300,35 600,50 T1200,50"
      fill="none"
      stroke="url(#waveGradient)"
      stroke-width="1"
      opacity="0.3"
    />
    <path
      d="M0,60 Q300,45 600,60 T1200,60"
      fill="none"
      stroke="url(#waveGradient)"
      stroke-width="1"
      opacity="0.2"
    />
    <!-- Subtle filled area under waves -->
    <path
      d="M0,40 Q300,20 600,40 T1200,40 L1200,120 L0,120 Z"
      fill="url(#waveGradient)"
      opacity="0.05"
    />
  </svg>
</div>
