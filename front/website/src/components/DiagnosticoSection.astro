---
---

<section class="diagnostico-section relative overflow-hidden px-8 py-16 lg:py-24 lg:px-16">
  <style>
    .diagnostico-section {
      background-color: #FAFBFE;
      background-image:
        linear-gradient(135deg, rgba(250, 251, 254, 0) 0%, rgba(245, 243, 255, 1) 100%),
        repeating-linear-gradient(90deg, transparent, transparent 2px, rgba(139, 92, 246, 0.03) 2px, rgba(139, 92, 246, 0.03) 4px),
        repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(139, 92, 246, 0.03) 2px, rgba(139, 92, 246, 0.03) 4px);
    }

    @keyframes revealUp {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: none;
      }
    }

    @keyframes drawLine {
      from {
        stroke-dashoffset: 1200;
      }
      to {
        stroke-dashoffset: 0;
      }
    }

    @keyframes ping {
      0% {
        transform: scale(1);
        opacity: 0.65;
      }
      70% {
        transform: scale(2.8);
        opacity: 0;
      }
      100% {
        transform: scale(2.8);
        opacity: 0;
      }
    }

    .line-path {
      stroke-dasharray: 1200;
      stroke-dashoffset: 1200;
      animation: drawLine 2s 0.3s ease forwards;
      filter: drop-shadow(0 2px 7px rgba(139, 92, 246, 0.5));
    }

    .ping-ring {
      transform-box: fill-box;
      transform-origin: center;
      animation: ping 2.4s ease-out infinite;
    }
  </style>

  <div class="mx-auto max-w-6xl">
    <div class="text-center mb-16">
      <h2 class="font-space-grotesk font-bold text-4xl lg:text-5xl text-[#181225] mb-4">
        ¿A qué nivel llega tu operación?
      </h2>
      <p class="text-lg text-[#6B6480] max-w-2xl mx-auto">
        Menos devoluciones, mes a mes. Así se ve una logística que aprende.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 mb-12">
      <!-- Left: Large Chart Card -->
      <div class="lg:col-span-2 bg-white border border-[#E5E0F0] rounded-3xl p-8 shadow-[0_10px_40px_-20px_rgba(124,58,237,0.2)]">
        <div class="flex justify-between items-start mb-8">
          <div>
            <div class="text-sm font-bold text-[#6B6480] mb-1">Ventas</div>
            <div class="text-xs text-[#9B94AD]">últimos 30 días</div>
          </div>
          <div class="text-sm font-bold text-emerald-600 bg-emerald-50 px-3 py-1 rounded-full">
            ↑ 12%
          </div>
        </div>

        <div class="relative h-56 mb-6">
          <svg
            viewBox="0 0 600 240"
            width="100%"
            height="100%"
            class="block overflow-visible"
          >
            <defs>
              <linearGradient id="lineGrad" x1="0" y1="0" x2="600" y2="0">
                <stop offset="0" stop-color="#A855F7" />
                <stop offset="1" stop-color="#7C3AED" />
              </linearGradient>
              <linearGradient id="areaGrad" x1="0" y1="0" x2="0" y2="240">
                <stop offset="0" stop-color="rgba(168, 85, 247, 0.25)" />
                <stop offset="1" stop-color="rgba(168, 85, 247, 0)" />
              </linearGradient>
            </defs>

            <path
              d="M20,160 L80,140 L140,155 L200,110 L260,130 L320,95 L380,115 L440,80 L500,100 L560,50 L560,240 L20,240 Z"
              fill="url(#areaGrad)"
            />
            <path
              class="line-path"
              d="M20,160 L80,140 L140,155 L200,110 L260,130 L320,95 L380,115 L440,80 L500,100 L560,50"
              fill="none"
              stroke="url(#lineGrad)"
              stroke-width="4"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
            <circle class="ping-ring" cx="560" cy="50" r="8" fill="none" stroke="#A855F7" stroke-width="2" />
            <circle cx="560" cy="50" r="5" fill="#A855F7" />
          </svg>
        </div>

        <div class="flex justify-between text-xs text-[#9B94AD]">
          <span>hace 30 días</span>
          <span>hoy</span>
        </div>
      </div>

      <!-- Right: Stacked Stats -->
      <div class="flex flex-col gap-4">
        <div class="bg-gradient-to-br from-purple-50 to-white border border-[#E5E0F0] rounded-2xl p-6 shadow-[0_10px_40px_-20px_rgba(124,58,237,0.2)]">
          <div class="text-4xl font-space-grotesk font-bold text-[#7C3AED] mb-2">
            <span data-count="20">0</span>
          </div>
          <div class="text-sm text-[#6B6480]">empresas confían en Probability</div>
        </div>

        <div class="bg-gradient-to-br from-purple-50 to-white border border-[#E5E0F0] rounded-2xl p-6 shadow-[0_10px_40px_-20px_rgba(124,58,237,0.2)]">
          <div class="text-4xl font-space-grotesk font-bold text-[#7C3AED] mb-2">
            <span data-count="12">0</span>M
          </div>
          <div class="text-sm text-[#6B6480]">ahorrados en logística</div>
        </div>

        <div class="bg-gradient-to-br from-emerald-50 to-white border border-[#E5E0F0] rounded-2xl p-6 shadow-[0_10px_40px_-20px_rgba(124,58,237,0.2)]">
          <div class="text-4xl font-space-grotesk font-bold text-emerald-600 mb-2">
            <span data-count="94">0</span>%
          </div>
          <div class="text-sm text-[#6B6480]">satisfacción de clientes</div>
        </div>
      </div>
    </div>

    <!-- CTA -->
    <div class="flex flex-col items-center gap-4 pt-8">
      <button class="open-quiz-modal inline-flex items-center gap-2 px-8 py-4 rounded-2xl font-bold text-white bg-gradient-to-r from-[#8B5CF6] to-[#7C3AED] shadow-[0_16px_34px_-12px_rgba(124,58,237,0.7)] hover:shadow-[0_20px_40px_-8px_rgba(124,58,237,0.8)] transition-all">
        Iniciar diagnóstico gratuito →
      </button>
      <div class="text-sm text-[#9B94AD]">
        Sin tarjeta · 100% gratuito · Resultados al instante
      </div>
    </div>
  </div>

  <script define:vars={{ dummy: true }}>
    (function () {
      const duration = 1500;
      const startTime = performance.now();
      const els = document.querySelectorAll('[data-count]');

      const frame = (now) => {
        const elapsed = now - startTime;
        const progress = Math.min(1, elapsed / duration);
        const easeOut = 1 - Math.pow(1 - progress, 3);

        els.forEach((el) => {
          const target = parseFloat(el.getAttribute('data-count'));
          el.textContent = Math.round(target * easeOut);
        });

        if (progress < 1) {
          requestAnimationFrame(frame);
        }
      };

      els.forEach((el) => {
        el.textContent = '0';
      });
      requestAnimationFrame(frame);
    })();
  </script>
</section>
