---
import '../styles/global.css';

interface Props {
	title?: string;
	description?: string;
}

const { title = 'probabilityIA - Predice y Reduce Devoluciones en Tiempo Real', description = 'Reduce devoluciones, aumenta ganancias. Crece con inteligencia artificial.' } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<base href="/website/" />
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="keywords" content="IA, devoluciones, ecommerce, predicción, logística" />
		<meta name="robots" content="index, follow" />
		<link rel="icon" type="image/png" href="/website/logo-icon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- Open Graph Tags -->
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content="/website/logo-icon.png" />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://www.probabilityia.com.co/website/" />
		<meta property="og:locale" content="es_CO" />

		<!-- Twitter Cards -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />

		<!-- Canonical Tag -->
		<link rel="canonical" href="https://www.probabilityia.com.co/website/" />

		<!-- JSON-LD Schema - Organization -->
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "Organization",
			"name": "ProbabilityIA",
			"url": "https://www.probabilityia.com.co",
			"logo": "https://www.probabilityia.com.co/website/logo.webp",
			"description": "Solución de inteligencia artificial para reducir devoluciones en ecommerce y optimizar operaciones logísticas",
			"sameAs": [
				"https://www.linkedin.com/company/probabilityia",
				"https://www.instagram.com/probabilityia",
				"https://www.facebook.com/probabilityia"
			],
			"contactPoint": {
				"@type": "ContactPoint",
				"contactType": "Customer Service",
				"email": "hola@probabilityia.com.co",
				"telephone": "+573138241302",
				"areaServed": "CO"
			},
			"address": {
				"@type": "PostalAddress",
				"addressCountry": "CO",
				"addressLocality": "Bogotá"
			}
		}
		</script>

		<!-- JSON-LD Schema - SoftwareApplication -->
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "SoftwareApplication",
			"name": "ProbabilityIA",
			"applicationCategory": "BusinessApplication",
			"description": "Plataforma IA para predicción y reducción de devoluciones en ecommerce",
			"url": "https://www.probabilityia.com.co/website/",
			"operatingSystem": "Web",
			"offers": {
				"@type": "Offer",
				"price": "Contactar",
				"priceCurrency": "COP",
				"availability": "https://schema.org/InStock"
			},
			"aggregateRating": {
				"@type": "AggregateRating",
				"ratingValue": "4.8",
				"ratingCount": "120",
				"reviewCount": "120"
			}
		}
		</script>
	</head>
	<body class="bg-white text-gray-900 antialiased">
		<slot />
	</body>
</html>
