---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import HeroSection from '../components/HeroSection.astro';
import BannerPromo from '../components/BannerPromo.astro';
import IntegrationsSection from '../components/IntegrationsSection.astro';
import HowItWorks from '../components/HowItWorks.astro';
import AdvantagesSection from '../components/AdvantagesSection.astro';
import FeaturesSection from '../components/FeaturesSection.astro';
import Footer from '../components/Footer.astro';
import QuizModal from '../components/QuizModal.astro';

const title = 'ProbabilityIA - Predice y Reduce Devoluciones en Ecommerce';
const description = 'Solución IA para reducir devoluciones. Aumenta ganancias, optimiza envíos y automatiza tu operación logística en tiempo real.';
---

<style>
	.whatsapp-float {
		position: fixed;
		bottom: 1rem;
		right: 1rem;
		z-index: 50;
	}

	.whatsapp-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 60px;
		height: 60px;
		background: transparent;
		border-radius: 50%;
		color: white;
		text-decoration: none;
		transition: all 0.3s ease;
		animation: pulse 3s ease-in-out infinite;
	}

	.whatsapp-btn:hover {
		transform: scale(1.2);
		filter: drop-shadow(0 0 20px rgba(34, 197, 94, 0.6));
	}

	.cta-section {
		background: #ffffff;
		border-top: 1px solid rgba(139, 92, 246, 0.1);
		padding: 4rem 1rem;
		position: relative;
		overflow: hidden;
	}

	.cta-section::before {
		content: '';
		position: absolute;
		top: 0;
		left: 0;
		right: 0;
		bottom: 0;
		background-image:
			repeating-linear-gradient(90deg, transparent, transparent 2px, rgba(139, 92, 246, 0.03) 2px, rgba(139, 92, 246, 0.03) 4px),
			repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(139, 92, 246, 0.03) 2px, rgba(139, 92, 246, 0.03) 4px);
		pointer-events: none;
	}

	.cta-container {
		max-width: 800px;
		margin: 0 auto;
		text-align: center;
		position: relative;
		z-index: 1;
	}

	.cta-section h2 {
		font-family: 'Plus Jakarta Sans', sans-serif;
		font-size: clamp(1.875rem, 5vw, 2.5rem);
		font-weight: 800;
		color: #8B5CF6;
		margin-bottom: 1rem;
		letter-spacing: -0.02em;
	}

	.cta-section p {
		color: #64748B;
		font-size: 1.0625rem;
		line-height: 1.6;
		margin-bottom: 2rem;
		max-width: 600px;
		margin-left: auto;
		margin-right: auto;
	}

	.cta-button {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(135deg, #8b5cf6, #a78bfa);
		color: #fff;
		border: none;
		font-family: 'Inter', sans-serif;
		font-weight: 600;
		font-size: 1rem;
		padding: 1rem 2.5rem;
		border-radius: 12px;
		cursor: pointer;
		box-shadow: 0 4px 14px rgba(139, 92, 246, 0.3);
		transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
	}

	.cta-button:hover {
		background: linear-gradient(135deg, #7c3aed, #8b5cf6);
		box-shadow: 0 6px 20px rgba(139, 92, 246, 0.42);
		transform: translateY(-2px);
	}

	.cta-button:active {
		transform: translateY(0);
	}

	@media (min-width: 640px) {
		.whatsapp-float {
			bottom: 2rem;
			right: 2rem;
		}

		.whatsapp-btn {
			width: 80px;
			height: 80px;
		}

		.cta-section {
			padding: 5rem 2rem;
		}
	}

	@keyframes pulse {
		0%, 100% {
			transform: scale(1);
		}
		50% {
			transform: scale(1.1);
		}
	}
</style>

<Layout title={title} description={description}>
	<Header />
	<div class="whatsapp-float">
		<a href="https://wa.me/573138241302?text=Hola%20ProbabilityIA%2C%20me%20interesa%20conocer%20más%20sobre%20tu%20plataforma" class="whatsapp-btn" title="Contactanos por WhatsApp">
			<img src="https://static.vecteezy.com/system/resources/previews/021/495/946/non_2x/whatsapp-logo-icon-free-png.png" alt="WhatsApp" class="w-9 sm:w-12 h-9 sm:h-12"/>
		</a>
	</div>
	<main>
		<HeroSection />
		<section class="cta-section">
			<div class="cta-container">
				<h2>¿A qué nivel llega tu operación?</h2>
				<p>Realiza nuestro diagnóstico logístico y descubre el potencial real de tu negocio. Solo 6 preguntas, 2 minutos.</p>
				<button class="cta-button open-quiz-modal">Iniciar diagnóstico gratuito</button>
			</div>
		</section>
		<BannerPromo />
		<IntegrationsSection />
		<HowItWorks />
		<AdvantagesSection />
		<FeaturesSection />
	</main>
	<QuizModal />
	<Footer />

	<script>
		document.querySelectorAll('.open-quiz-modal').forEach(btn => {
			btn.addEventListener('click', () => {
				window.openQuizModal?.();
			});
		});
	</script>
</Layout>
