---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import HeroSection from '../components/HeroSection.astro';
import BannerPromo from '../components/BannerPromo.astro';
import IntegrationsSection from '../components/IntegrationsSection.astro';
import HowItWorks from '../components/HowItWorks.astro';
import AdvantagesSection from '../components/AdvantagesSection.astro';
import FeaturesSection from '../components/FeaturesSection.astro';
import Footer from '../components/Footer.astro';
import QuizModal from '../components/QuizModal.astro';

const title = 'ProbabilityIA - Predice y Reduce Devoluciones en Ecommerce';
const description = 'Solución IA para reducir devoluciones. Aumenta ganancias, optimiza envíos y automatiza tu operación logística en tiempo real.';
---

<style>
	.whatsapp-float {
		position: fixed;
		bottom: 1rem;
		right: 1rem;
		z-index: 50;
	}

	.whatsapp-btn {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 60px;
		height: 60px;
		background: transparent;
		border-radius: 50%;
		color: white;
		text-decoration: none;
		transition: all 0.3s ease;
		animation: pulse 3s ease-in-out infinite;
	}

	.whatsapp-btn:hover {
		transform: scale(1.2);
		filter: drop-shadow(0 0 20px rgba(34, 197, 94, 0.6));
	}

	@keyframes ctaFloat {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-20px); }
	}

	@keyframes ctaPulseRing {
		0% { transform: scale(0.92); opacity: 0.55; }
		70% { transform: scale(1.18); opacity: 0; }
		100% { transform: scale(1.18); opacity: 0; }
	}

	@keyframes ctaDash {
		to { stroke-dashoffset: -32; }
	}

	@keyframes ctaBox {
		0%, 100% { transform: translateY(0); }
		50% { transform: translateY(-6px); }
	}

	.cta-section {
		background: #ffffff;
		border-top: 1px solid rgba(139, 92, 246, 0.1);
		padding: 2rem 1.25rem;
		position: relative;
		overflow: hidden;
		font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
	}

	.cta-section::before {
		content: '';
		position: absolute;
		inset: 0;
		background-image:
			repeating-linear-gradient(45deg, rgba(139, 92, 246, 0.03) 0, rgba(139, 92, 246, 0.03) 1px, transparent 1px, transparent 11px),
			repeating-linear-gradient(-45deg, rgba(139, 92, 246, 0.03) 0, rgba(139, 92, 246, 0.03) 1px, transparent 1px, transparent 11px);
		pointer-events: none;
	}

	.cta-section::after {
		content: '';
		position: absolute;
		top: -120px;
		right: -80px;
		width: 380px;
		height: 380px;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(139, 92, 246, 0.1) 0%, transparent 70%);
		pointer-events: none;
	}

	.cta-bg-circle {
		position: absolute;
		bottom: -140px;
		left: -90px;
		width: 340px;
		height: 340px;
		border-radius: 50%;
		background: radial-gradient(circle, rgba(139, 92, 246, 0.07) 0%, transparent 70%);
		pointer-events: none;
	}

	.cta-container {
		max-width: 1080px;
		margin: 0 auto;
		position: relative;
		z-index: 1;
	}

	.cta-header {
		text-align: center;
		max-width: 680px;
		margin: 0 auto 0.8rem;
	}

	.cta-badge {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		padding: 0.3rem 0.7rem;
		border: 1px solid rgba(139, 92, 246, 0.2);
		border-radius: 999px;
		background: rgba(139, 92, 246, 0.05);
		color: #8B5CF6;
		font-size: 0.7rem;
		font-weight: 600;
		letter-spacing: 0.02em;
		margin-bottom: 0.5rem;
	}

	.cta-badge-dot {
		width: 7px;
		height: 7px;
		border-radius: 50%;
		background: #8B5CF6;
		box-shadow: 0 0 0 4px rgba(139, 92, 246, 0.18);
	}

	.cta-section h2 {
		color: #8B5CF6;
		font-size: clamp(1.375rem, 3vw, 2rem);
		font-weight: 800;
		line-height: 1.05;
		margin: 0 0 0.4rem;
		letter-spacing: -0.02em;
	}

	.cta-section p {
		color: #64748B;
		font-size: 0.875rem;
		line-height: 1.4;
		margin: 0;
	}

	.cta-grid {
		display: grid;
		grid-template-columns: 1.05fr 1fr;
		gap: 1.5rem;
		align-items: center;
		margin-bottom: 0.3rem;
	}

	.cta-illu-col {
		display: flex;
		justify-content: center;
	}

	.cta-illu-wrapper {
		position: relative;
		width: 100%;
		max-width: 340px;
		aspect-ratio: 1 / 1;
		margin: 0 auto;
	}

	.cta-illu-pulse {
		position: absolute;
		inset: 8%;
		border-radius: 50%;
		border: 1.5px dashed rgba(139, 92, 246, 0.22);
		animation: ctaPulseRing 3.2s ease-out infinite;
	}

	.cta-illu-inner {
		position: absolute;
		inset: 0;
		display: flex;
		align-items: center;
		justify-content: center;
		transform: translateY(-30px);
	}

	.cta-stats-col {
		display: flex;
		flex-direction: column;
		gap: 0.6rem;
	}

	.cta-stat-card {
		background: #ffffff;
		border: 1px solid rgba(139, 92, 246, 0.2);
		border-radius: 12px;
		padding: 0.85rem 1rem;
		box-shadow: 0 4px 14px rgba(139, 92, 246, 0.07);
		transform: scale(1);
		transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
		cursor: default;
		display: flex;
		align-items: center;
		gap: 0.75rem;
	}

	.cta-stat-card:hover {
		border-color: rgba(139, 92, 246, 0.55);
		box-shadow: 0 12px 28px rgba(139, 92, 246, 0.18);
		transform: scale(1.03);
	}

	.cta-stat-icon {
		flex-shrink: 0;
		width: 36px;
		height: 36px;
		border-radius: 8px;
		background: rgba(139, 92, 246, 0.08);
		display: flex;
		align-items: center;
		justify-content: center;
		color: #8B5CF6;
	}

	.cta-stat-value {
		font-size: 1.375rem;
		font-weight: 800;
		color: #8B5CF6;
		line-height: 1;
		letter-spacing: -0.02em;
	}

	.cta-stat-label {
		font-size: 0.75rem;
		color: #64748B;
		font-weight: 500;
		margin-top: 0.15rem;
	}

	.cta-button {
		display: inline-flex;
		align-items: center;
		gap: 0.4rem;
		font-family: 'Plus Jakarta Sans', system-ui, sans-serif;
		font-size: 0.875rem;
		font-weight: 700;
		color: #ffffff;
		border: none;
		cursor: pointer;
		padding: 0.75rem 1.6rem;
		border-radius: 11px;
		background: linear-gradient(135deg, #A78BFA 0%, #8B5CF6 55%, #7C3AED 100%);
		box-shadow: 0 10px 26px rgba(139, 92, 246, 0.32);
		transform: translateY(0);
		transition: transform 0.25s ease, box-shadow 0.25s ease;
	}

	.cta-button:hover {
		box-shadow: 0 16px 36px rgba(139, 92, 246, 0.42);
		transform: translateY(-3px);
	}

	.cta-button svg {
		width: 14px;
		height: 14px;
		transition: transform 0.25s ease;
	}

	.cta-button:hover svg {
		transform: translateX(4px);
	}

	.cta-footer {
		text-align: center;
		color: #94A3B8;
		font-size: 0.7rem;
		margin-top: 0.5rem;
		font-weight: 500;
	}

	@media (max-width: 860px) {
		.cta-grid {
			grid-template-columns: 1fr;
		}

		.cta-illu-col {
			order: 2;
		}

		.cta-stats-col {
			order: 1;
		}
	}

	@media (min-width: 640px) {
		.whatsapp-float {
			bottom: 2rem;
			right: 2rem;
		}

		.whatsapp-btn {
			width: 80px;
			height: 80px;
		}

		.cta-section {
			padding: 5rem 2rem;
		}
	}

	@keyframes pulse {
		0%, 100% {
			transform: scale(1);
		}
		50% {
			transform: scale(1.1);
		}
	}
</style>

<Layout title={title} description={description}>
	<Header />
	<div class="whatsapp-float">
		<a href="https://wa.me/573138241302?text=Hola%20ProbabilityIA%2C%20me%20interesa%20conocer%20más%20sobre%20tu%20plataforma" class="whatsapp-btn" title="Contactanos por WhatsApp">
			<img src="https://static.vecteezy.com/system/resources/previews/021/495/946/non_2x/whatsapp-logo-icon-free-png.png" alt="WhatsApp" class="w-9 sm:w-12 h-9 sm:h-12"/>
		</a>
	</div>
	<main>
		<HeroSection />
		<section class="cta-section">
			<div class="cta-bg-circle"></div>
			<div class="cta-container">
				<div class="cta-header">
					<div class="cta-badge">
						<span class="cta-badge-dot"></span>
						Diagnóstico logístico gratuito
					</div>
					<h2>¿A qué nivel llega tu operación?</h2>
					<p>Realiza nuestro diagnóstico y descubre en minutos las oportunidades de mejora ocultas en tu cadena logística. Sin compromiso, con resultados accionables.</p>
				</div>

				<div style="display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: start; margin-bottom: 1.5rem; margin-top: 1.5rem;">
					<div style="display: flex; flex-direction: column; align-items: center; gap: 1.5rem;">
						<div class="cta-illu-wrapper">
							<div class="cta-illu-inner">
								<svg width="82%" height="82%" viewBox="0 0 240 240" fill="none" style="overflow: visible;">
									<!-- warehouse roof -->
									<path d="M40 96 L120 52 L200 96" stroke="#8B5CF6" stroke-width="4" stroke-linecap="round" stroke-linejoin="round" fill="none" />
									<!-- warehouse body -->
									<rect x="52" y="96" width="136" height="96" rx="8" stroke="#8B5CF6" stroke-width="4" fill="rgba(139,92,246,0.04)" />
									<!-- door -->
									<rect x="102" y="138" width="36" height="54" rx="4" stroke="#8B5CF6" stroke-width="3" fill="#ffffff" />
									<line x1="120" y1="138" x2="120" y2="192" stroke="rgba(139,92,246,0.4)" stroke-width="2" />
									<!-- shelf boxes left -->
									<rect x="66" y="116" width="24" height="18" rx="3" fill="rgba(139,92,246,0.18)" stroke="#8B5CF6" stroke-width="2" style="transform-origin: 78px 125px; animation: ctaBox 4s ease-in-out infinite;" />
									<rect x="66" y="150" width="24" height="16" rx="3" fill="rgba(148,163,184,0.18)" stroke="#94A3B8" stroke-width="2" />
									<!-- shelf boxes right -->
									<rect x="150" y="116" width="24" height="18" rx="3" fill="rgba(148,163,184,0.18)" stroke="#94A3B8" stroke-width="2" />
									<rect x="150" y="150" width="24" height="16" rx="3" fill="rgba(139,92,246,0.18)" stroke="#8B5CF6" stroke-width="2" style="transform-origin: 162px 158px; animation: ctaBox 4s ease-in-out 0.8s infinite;" />
									<!-- floating package flow arrow -->
									<path d="M44 70 Q120 16 196 70" stroke="#8B5CF6" stroke-width="2.5" stroke-dasharray="6 8" fill="none" style="animation: ctaDash 1.6s linear infinite;" />
									<!-- efficiency package -->
									<g style="transform-origin: 120px 36px; animation: ctaBox 4s ease-in-out 0.4s infinite;">
										<rect x="108" y="24" width="24" height="24" rx="4" fill="#ffffff" stroke="#8B5CF6" stroke-width="3" />
										<path d="M108 32 L132 32 M120 24 L120 48" stroke="#8B5CF6" stroke-width="2" />
									</g>
								</svg>
							</div>
						</div>
					</div>

					<div class="cta-stats-col">
						<div class="cta-stat-card">
							<div class="cta-stat-icon">
								<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
									<path d="M3 21h18" />
									<path d="M5 21V5l7-2 7 2v16" />
									<path d="M9 9h.01M12 9h.01M15 9h.01M9 13h.01M12 13h.01M15 13h.01" />
								</svg>
							</div>
							<div>
								<div class="cta-stat-value">20</div>
								<div class="cta-stat-label">Empresas diagnosticadas</div>
							</div>
						</div>

						<div class="cta-stat-card">
							<div class="cta-stat-icon">
								<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
									<circle cx="12" cy="12" r="9" />
									<path d="M15.5 8.5a4 4 0 1 0 0 7M8 11h5M8 13.5h5" />
								</svg>
							</div>
							<div>
								<div class="cta-stat-value">$45M</div>
								<div class="cta-stat-label">Ahorro anual generado</div>
							</div>
						</div>

						<div class="cta-stat-card">
							<div class="cta-stat-icon">
								<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.9" stroke-linecap="round" stroke-linejoin="round">
									<circle cx="12" cy="12" r="9" />
									<path d="M8 14s1.5 2 4 2 4-2 4-2M9 9h.01M15 9h.01" />
								</svg>
							</div>
							<div>
								<div class="cta-stat-value">94%</div>
								<div class="cta-stat-label">Satisfacción de usuarios</div>
							</div>
						</div>
					</div>
				</div>

				<div style="text-align: center;">
					<button class="cta-button open-quiz-modal">
						Iniciar diagnóstico gratuito
						<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"></path></svg>
					</button>
					<div class="cta-footer">Sin tarjeta · 100% gratuito · Resultados al instante</div>
				</div>
			</div>
		</section>
		<BannerPromo />
		<IntegrationsSection />
		<HowItWorks />
		<AdvantagesSection />
		<FeaturesSection />
	</main>
	<QuizModal />
	<Footer />

	<script>
		document.querySelectorAll('.open-quiz-modal').forEach(btn => {
			btn.addEventListener('click', () => {
				window.openQuizModal?.();
			});
		});
	</script>
</Layout>
