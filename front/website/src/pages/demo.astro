---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const title = 'Demo Gratis - Prueba ProbabilityIA por 30 Minutos';
const description = 'Solicita tu demo gratuita con uno de nuestros expertos. Sin tarjeta de crédito. Conoce cómo funcionamos.';
---

<style>
	@keyframes float {
		0%, 100% {
			transform: translateY(0px);
		}
		50% {
			transform: translateY(-20px);
		}
	}

	.blob {
		position: absolute;
		border-radius: 50%;
		filter: blur(60px);
		opacity: 0.1;
		animation: float 6s ease-in-out infinite;
	}

	.gradient-text {
		background: linear-gradient(135deg, #8B5CF6 0%, #A855F7 100%);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
</style>

<Layout title={title} description={description}>
	<Header />
	<main>
		<!-- Hero Section -->
		<section class="relative bg-gradient-to-br from-white via-purple-50 to-white py-20 px-6 sm:px-20 overflow-hidden">
			<div class="blob" style="width: 400px; height: 400px; background: #8B5CF6; top: -100px; right: -100px;"></div>
			<div class="blob" style="width: 300px; height: 300px; background: #A855F7; bottom: -50px; left: -50px; animation-delay: 2s;"></div>
			<div class="max-w-4xl mx-auto text-center relative z-10">
				<div class="inline-flex items-center gap-2 bg-purple-100 border border-purple-300 rounded-full px-4 py-2 mb-6 hover:bg-purple-200 transition-colors">
					<span class="text-[#8B5CF6] font-medium text-sm">DEMO GRATUITA</span>
				</div>
				<h1 class="text-5xl sm:text-6xl lg:text-7xl font-extrabold text-gray-900 mb-6 leading-tight">
					Ve ProbabilityIA en <span class="gradient-text">acción</span>
				</h1>
				<p class="text-lg sm:text-xl text-gray-600 max-w-3xl mx-auto">
					Regístrate con tu correo y recibe información detallada sobre cómo transformar tu negocio
				</p>
			</div>
		</section>

		<!-- Demo Form Section -->
		<section class="bg-white py-20 px-6 sm:px-20">
			<div class="max-w-2xl mx-auto">
				<div class="bg-gradient-to-br from-purple-50 to-white border border-purple-200 rounded-2xl p-12">
					<form id="demoForm" class="space-y-6">
						<!-- Email -->
						<div>
							<label class="block text-gray-700 font-semibold mb-2">Tu Correo Electrónico</label>
							<input type="email" id="demoEmail" required placeholder="tu@email.com" class="w-full bg-white border border-purple-200 rounded-lg px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:border-[#8B5CF6] focus:ring-2 focus:ring-purple-200 transition-colors"/>
							<p class="text-sm text-gray-600 mt-2">Recibirás un mensaje automático con toda la información de probabilityIA</p>
						</div>

						<!-- Submit -->
						<button type="submit" class="w-full bg-gradient-to-r from-[#8B5CF6] to-[#A855F7] hover:from-[#7C3AED] hover:to-[#9333EA] text-white py-4 rounded-lg font-bold text-lg transition-colors mt-8">
							Recibir Información
						</button>
					</form>

					<!-- Success Message -->
					<div id="successMessage" class="hidden mt-6 p-4 bg-green-50 border border-green-200 rounded-lg">
						<p class="text-green-800 font-semibold">✓ ¡Perfecto!</p>
						<p class="text-green-700 text-sm mt-1">Te hemos enviado un mensaje con toda la información de probabilityIA. Revisa tu correo en los próximos momentos.</p>
					</div>
				</div>

				<!-- Benefits -->
				<div class="mt-16 grid grid-cols-1 md:grid-cols-3 gap-8">
					<div class="text-center">
						<div class="w-12 h-12 rounded-lg bg-purple-100 border border-purple-300 flex items-center justify-center mx-auto mb-4">
							<svg class="w-6 h-6 text-[#8B5CF6]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
						</div>
						<h3 class="text-gray-900 font-semibold mb-2">Información Completa</h3>
						<p class="text-gray-600 text-sm">Recibe detalles sobre características, precios y casos de éxito</p>
					</div>

					<div class="text-center">
						<div class="w-12 h-12 rounded-lg bg-purple-100 border border-purple-300 flex items-center justify-center mx-auto mb-4">
							<svg class="w-6 h-6 text-[#8B5CF6]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
						</div>
						<h3 class="text-gray-900 font-semibold mb-2">Rápido y Sencillo</h3>
						<p class="text-gray-600 text-sm">Solo necesitas tu correo electrónico, sin formularios complicados</p>
					</div>

					<div class="text-center">
						<div class="w-12 h-12 rounded-lg bg-purple-100 border border-purple-300 flex items-center justify-center mx-auto mb-4">
							<svg class="w-6 h-6 text-[#8B5CF6]" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
						</div>
						<h3 class="text-gray-900 font-semibold mb-2">Sin Compromiso</h3>
						<p class="text-gray-600 text-sm">Conoce nuestro producto sin obligación de compra</p>
					</div>
				</div>
			</div>
		</section>

		<!-- What You'll Get Section -->
		<section class="bg-gradient-to-br from-purple-50 via-white to-purple-50 py-20 px-6 sm:px-20">
			<div class="max-w-4xl mx-auto">
				<h2 class="text-3xl font-bold text-gray-900 text-center mb-12">¿Qué recibirás?</h2>
				<div class="space-y-4">
					<div class="bg-white border border-purple-200 rounded-lg p-6">
						<div class="flex items-start gap-4">
							<div class="w-8 h-8 rounded-full bg-purple-100 flex items-center justify-center flex-shrink-0 mt-1">
								<span class="text-[#8B5CF6] font-bold text-sm">1</span>
							</div>
							<div>
								<h3 class="font-semibold text-gray-900 mb-2">Descripción Completa del Producto</h3>
								<p class="text-gray-600">Conoce todas las características de probabilityIA y cómo pueden transformar tu negocio</p>
							</div>
						</div>
					</div>

					<div class="bg-white border border-purple-200 rounded-lg p-6">
						<div class="flex items-start gap-4">
							<div class="w-8 h-8 rounded-full bg-purple-100 flex items-center justify-center flex-shrink-0 mt-1">
								<span class="text-[#8B5CF6] font-bold text-sm">2</span>
							</div>
							<div>
								<h3 class="font-semibold text-gray-900 mb-2">Casos de Éxito</h3>
								<p class="text-gray-600">Descubre cómo empresas como la tuya han aumentado su rentabilidad y reducido devoluciones</p>
							</div>
						</div>
					</div>

					<div class="bg-white border border-purple-200 rounded-lg p-6">
						<div class="flex items-start gap-4">
							<div class="w-8 h-8 rounded-full bg-purple-100 flex items-center justify-center flex-shrink-0 mt-1">
								<span class="text-[#8B5CF6] font-bold text-sm">3</span>
							</div>
							<div>
								<h3 class="font-semibold text-gray-900 mb-2">Información de Precios y Planes</h3>
								<p class="text-gray-600">Conoce nuestros planes de precios flexible adaptados a tu tamaño de negocio</p>
							</div>
						</div>
					</div>

					<div class="bg-white border border-purple-200 rounded-lg p-6">
						<div class="flex items-start gap-4">
							<div class="w-8 h-8 rounded-full bg-purple-100 flex items-center justify-center flex-shrink-0 mt-1">
								<span class="text-[#8B5CF6] font-bold text-sm">4</span>
							</div>
							<div>
								<h3 class="font-semibold text-gray-900 mb-2">Próximos Pasos</h3>
								<p class="text-gray-600">Información sobre cómo agendar una demostración personalizada con nuestro equipo</p>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>
	</main>
	<Footer />
</Layout>

<script>
	const demoForm = document.getElementById('demoForm');
	const successMessage = document.getElementById('successMessage');

	if (demoForm) {
		demoForm.addEventListener('submit', (e) => {
			e.preventDefault();

			const email = (document.getElementById('demoEmail') as HTMLInputElement)?.value || '';

			// Validar email
			if (!email) {
				alert('Por favor ingresa tu correo electrónico');
				return;
			}

			// Validar formato de email
			const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
			if (!emailRegex.test(email)) {
				alert('Por favor ingresa un correo válido');
				return;
			}

			// Mensaje con información automática de probabilityIA
			const infoMessage = `¡Hola!

Gracias por tu interés en probabilityIA. Te compartimos la siguiente información:

📊 SOBRE PROBABILITYIA
ProbabilityIA es una plataforma de inteligencia artificial que ayuda a e-commerce y negocios de retail a:
• Reducir devoluciones con predicción de 99.8% de precisión
• Automatizar procesos de análisis de productos y envíos
• Integración instantánea con Shopify, Mercado Libre, WooCommerce y más
• Análisis en tiempo real de riesgos operacionales

💰 BENEFICIOS CLAVE
✓ Aumento de rentabilidad: +45% promedio
✓ Reducción de devoluciones: -78% en los primeros 3 meses
✓ ROI: Recupera tu inversión en 2-3 meses
✓ Soporte 24/7 dedicado

🚀 CARACTERÍSTICAS PRINCIPALES
1. Predicción de Devoluciones - Identifica pedidos de riesgo antes de procesarlos
2. Análisis de Imágenes - Detecta problemas de calidad automáticamente
3. Dashboard Inteligente - Métricas en tiempo real de tu negocio
4. Alertas Automáticas - Notificaciones de riesgos potenciales
5. Integraciones - Compatible con tus plataformas actuales

📈 CASOS DE ÉXITO
• TechVision Co. (Bogotá): +78% productividad
• LogisticaX (Medellín): 92% menos errores
• FinanceHub (Lima): 10x más rápido en reportes
• RetailPro (Santiago): 45% más conversiones

💳 PLANES DISPONIBLES
• Plan Startup: Hasta 1,000 pedidos/mes
• Plan Professional: Hasta 10,000 pedidos/mes
• Plan Enterprise: Ilimitado + Soporte Personalizado

📞 PRÓXIMOS PASOS
1. Agenda una demostración personalizada: /demo
2. Contáctanos por WhatsApp: +57 313 824 1302
3. Correo: gerencia@probabilityapp.com

¡Queremos ayudarte a transformar tu negocio con IA!

---
Equipo ProbabilityIA`;

			// Crear mensaje para WhatsApp
			const whatsappMessage = `*SOLICITUD DE INFORMACIÓN - PROBABILITYIA*

📧 *Email:* ${email}

El usuario ha solicitado información automática sobre probabilityIA.`;

			// Aquí puedes agregar lógica para enviar email real
			// Por ahora, usaremos WhatsApp para confirmar la solicitud
			const encodedMessage = encodeURIComponent(whatsappMessage);
			const whatsappPhone = '573138241302';
			const whatsappUrl = `https://wa.me/${whatsappPhone}?text=${encodedMessage}`;

			// Mostrar mensaje de éxito
			if (successMessage) {
				successMessage.classList.remove('hidden');
			}

			demoForm.reset();

			// Redirigir a WhatsApp para confirmar
			setTimeout(() => {
				window.open(whatsappUrl, '_blank');
			}, 2000);
		});
	}
</script>
